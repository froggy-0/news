{# 변수: news_source_items, market_source_lines, data_quality_status, footer_notes, unsubscribe_url, github_url #}
{% from "email_macros.html.j2" import section_label %}
<tr><td style="padding:0;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
<tr>
<td class="section-pad" style="padding:34px 40px 20px 40px;">
{{ section_label("출처와 데이터", "#02e600") }}
{% if news_source_items %}
<div style="padding-top:20px;font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#888888;font-size:10px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;" class="text-muted">뉴스 출처</div>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="padding-top:8px;">
{% for item in news_source_items %}
<tr>
<td style="padding:10px 0;border-top:1px solid #1c1b1b;font-family:'Apple SD Gothic Neo','Noto Sans KR','Malgun Gothic',sans-serif;color:#888888;font-size:13px;line-height:1.7;" class="text-muted">{{ item.source_kind }}</td>
<td align="right" style="padding:10px 0;border-top:1px solid #1c1b1b;font-family:'Apple SD Gothic Neo','Noto Sans KR','Malgun Gothic',sans-serif;color:#ffffff;font-size:14px;line-height:1.7;font-weight:700;" class="text-strong">{% if item.safe_url %}<a href="{{ item.safe_url }}" style="color:#ffffff;text-decoration:none;">{{ item.source_name }}</a>{% else %}{{ item.source_name }}{% endif %}</td>
</tr>
{% endfor %}
</table>
{% endif %}

<div style="padding-top:22px;font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#888888;font-size:10px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;" class="text-muted">시장 데이터</div>
{% for line in market_source_lines %}
<div style="padding-top:10px;font-family:'Apple SD Gothic Neo','Noto Sans KR','Malgun Gothic',sans-serif;color:#c6c6c6;font-size:14px;line-height:1.8;" class="text-body">· {{ line }}</div>
{% endfor %}

<div style="padding-top:22px;font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#888888;font-size:10px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;" class="text-muted">수집 기준</div>
<div style="padding-top:10px;font-family:'Apple SD Gothic Neo','Noto Sans KR','Malgun Gothic',sans-serif;color:#c6c6c6;font-size:14px;line-height:1.85;" class="text-body">뉴욕 마감 이후 공개 시장 데이터와 검증된 뉴스, 공식 X 시그널을 바탕으로 요약했습니다.</div>

{% if data_quality_status != "ok" and footer_notes %}
<div style="padding-top:22px;font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#888888;font-size:10px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;" class="text-muted">데이터 처리 메모</div>
{% for note in footer_notes %}
<div style="padding-top:8px;font-family:'Apple SD Gothic Neo','Noto Sans KR','Malgun Gothic',sans-serif;color:#888888;font-size:13px;line-height:1.8;" class="text-muted">· {{ note }}</div>
{% endfor %}
{% endif %}
</td>
</tr>
<tr>
<td class="section-pad" style="padding:0 40px 30px 40px;">
<div style="padding-top:18px;border-top:1px solid #1c1b1b;text-align:center;font-family:'Apple SD Gothic Neo','Noto Sans KR','Malgun Gothic',sans-serif;">
<div class="text-muted" style="color:#888888;font-size:11px;line-height:1.8;">본 메일은 공개 시장 데이터 기반 정보성 브리핑이며 투자 권유가 아닙니다.</div>
<div style="padding-top:6px;">
<a href="{{ unsubscribe_url }}" style="color:#888888;font-size:11px;text-decoration:underline;">구독 해지</a>
<span style="color:#555555;font-size:11px;"> &#183; </span>
<a href="{{ github_url }}" style="color:#888888;font-size:11px;text-decoration:underline;">GitHub</a>
</div>
</div>
</td>
</tr>
</table>
</td></tr>
