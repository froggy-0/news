<!doctype html>
<html lang="ko">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="color-scheme" content="light dark">
    <meta name="supported-color-schemes" content="light dark">
    <title>{{ subject }}</title>
    <!--[if mso]>
    <style>
      .card { border-radius: 0 !important; }
      .hero-accent { border-top: 4px solid #1e40af !important; }
    </style>
    <![endif]-->
    <style>
      :root {
        color-scheme: light dark;
      }
      @media (prefers-color-scheme: dark) {
        body,
        .shell {
          background: #111111 !important;
        }
        .card {
          background: #1a1a1a !important;
          border-color: #2a2a2a !important;
          box-shadow: none !important;
        }
        .section-fill {
          background: #1f1f1f !important;
        }
        .text-strong,
        .text-body,
        .text-link {
          color: #e8e8e3 !important;
          -webkit-text-fill-color: #e8e8e3 !important;
        }
        .text-subtle,
        .text-muted,
        .source-name {
          color: #9ca3af !important;
          -webkit-text-fill-color: #9ca3af !important;
        }
        .rule {
          border-color: #2a2a2a !important;
        }
        .pct-up {
          color: #4ade80 !important;
          -webkit-text-fill-color: #4ade80 !important;
        }
        .pct-down {
          color: #f87171 !important;
          -webkit-text-fill-color: #f87171 !important;
        }
        .pct-flat {
          color: #9ca3af !important;
          -webkit-text-fill-color: #9ca3af !important;
        }
        a {
          color: #93c5fd !important;
        }
        .notice-card {
          background: #331a00 !important;
          border-color: #92400e !important;
          color: #fbbf24 !important;
        }
        .hero-accent {
          border-color: #3b82f6 !important;
        }
        .watch-accent {
          border-color: #a78bfa !important;
        }
        .kospi-box {
          background: #14291e !important;
        }
        .hero-box {
          background: #1a2332 !important;
        }
      }
      @media screen and (max-width: 600px) {
        .shell-pad {
          padding: 12px 8px !important;
        }
        .card-pad {
          padding: 16px !important;
        }
        .hero-title {
          font-size: 24px !important;
        }
        .layer-one {
          font-size: 22px !important;
        }
        .news-headline {
          font-size: 18px !important;
        }
        .text-body {
          font-size: 15px !important;
        }
        .source-row td {
          display: block !important;
        }
        .source-name {
          display: block !important;
          padding-top: 4px !important;
          text-align: left !important;
        }
        .card {
          border-radius: 12px !important;
        }
        a {
          min-height: 44px;
          display: inline-block;
          line-height: 44px;
        }
        .footer-link {
          padding: 8px 16px !important;
        }
      }
    </style>
  </head>
  <body style="margin:0;padding:0;background:#f5f5f0;">
    <div style="display:none;max-height:0;overflow:hidden;opacity:0;color:transparent;">
      {{ preheader }}
    </div>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="shell" style="width:100%;background:#f5f5f0;">
      <tr>
        <td align="center" class="shell-pad" style="padding:24px 14px;">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width:640px;">

            {# ── 헤더 카드 ── #}
            <tr>
              <td style="padding:0 0 14px 0;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="card" style="width:100%;background:#ffffff;border:1px solid #e2e8f0;border-radius:16px;box-shadow:0 2px 8px rgba(15,23,42,0.04);">
                  <tr>
                    <td class="card-pad" style="padding:24px 24px 20px 24px;">
                      <div class="hero-title text-strong" style="font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#0f172a;font-size:20px;line-height:1.2;font-weight:700;letter-spacing:-0.02em;">Morning Market Brief</div>
                      <div class="text-subtle" style="padding-top:8px;font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#64748b;font-size:14px;line-height:1.6;font-weight:600;">{{ display_date or title }}</div>
                      <div class="rule" style="margin-top:16px;border-top:1px solid #e2e8f0;"></div>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            {# ── 데이터 품질 알림 ── #}
            {% if notice %}
            <tr>
              <td style="padding:0 0 14px 0;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="card notice-card section-fill" style="width:100%;background:#fff7ed;border:1px solid #fdba74;border-radius:16px;">
                  <tr>
                    <td class="card-pad" style="padding:16px 18px;font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#9a3412;font-size:14px;line-height:1.7;font-weight:700;">
                      {{ notice }}
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
            {% endif %}

            {# ── ① 핵심 요약 카드 (히어로) ── #}
            <tr>
              <td style="padding:0 0 14px 0;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="card hero-accent" style="width:100%;background:#ffffff;border:1px solid #e2e8f0;border-top:4px solid #1e40af;border-radius:0 0 16px 16px;box-shadow:0 2px 8px rgba(15,23,42,0.04);">
                  <tr>
                    <td class="card-pad" style="padding:22px;">
                      <div class="text-subtle" style="font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#1e40af;font-size:13px;line-height:1.4;font-weight:600;">오늘 핵심 요약</div>
                      {% if top_summary_lines %}
                      {% for line in top_summary_lines %}
                      <div style="padding-top:{% if loop.first %}12{% else %}14{% endif %}px;">
                        {% if not loop.first and summary_labels is defined and loop.index0 < summary_labels|length %}
                        <div class="text-subtle" style="font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#64748b;font-size:13px;line-height:1.4;font-weight:700;">{{ summary_labels[loop.index0] }}</div>
                        {% endif %}
                        <div class="{% if loop.first %}layer-one hero-box {% endif %}text-strong" style="{% if loop.first %}background:#f0f4ff;padding:14px 16px;border-radius:8px;{% endif %}font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#0f172a;font-size:{% if loop.first %}28{% else %}18{% endif %}px;line-height:1.55;font-weight:{% if loop.first %}800{% else %}700{% endif %};letter-spacing:{% if loop.first %}-0.03em{% else %}-0.01em{% endif %};font-variant-numeric:tabular-nums;">{{ line }}</div>
                      </div>
                      {% endfor %}
                      {% else %}
                      <div class="layer-one text-strong" style="padding-top:12px;font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#0f172a;font-size:28px;line-height:1.45;font-weight:800;letter-spacing:-0.03em;font-variant-numeric:tabular-nums;">{{ layer_one_html }}</div>
                      {% endif %}

                      {# 핵심 수치 #}
                      {% if key_metrics %}
                      <div class="rule" style="margin-top:16px;border-top:1px solid #e2e8f0;"></div>
                      <div style="padding-top:12px;">
                        {% for metric in key_metrics %}
                        <div class="text-body" style="padding-top:{% if loop.first %}0{% else %}6{% endif %}px;font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#334155;font-size:15px;line-height:1.6;font-variant-numeric:tabular-nums;">· {{ metric }}</div>
                        {% endfor %}
                      </div>
                      {% endif %}

                      {# 코스피 영향 #}
                      {% if kospi_impact %}
                      <div class="kospi-box" style="margin-top:12px;background:#f0fdf4;padding:12px 16px;border-radius:8px;">
                        <div class="text-body" style="font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#166534;font-size:15px;line-height:1.6;">🇰🇷 {{ kospi_impact }}</div>
                      </div>
                      {% endif %}
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            {# ── ② 주요 뉴스 카드 ── #}
            {% if news_items or news_fallback_text %}
            <tr>
              <td style="padding:0 0 14px 0;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="card" style="width:100%;background:#ffffff;border:1px solid #e2e8f0;border-radius:16px;box-shadow:0 2px 8px rgba(15,23,42,0.04);">
                  <tr>
                    <td class="card-pad" style="padding:22px;">
                      <div class="text-subtle" style="font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#1e40af;font-size:13px;line-height:1.4;font-weight:600;">📰 주요 뉴스와 시장 의미</div>
                      {% if news_context %}
                      <div class="text-body" style="padding-top:10px;font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#475569;font-size:14px;line-height:1.6;font-style:italic;">{{ news_context }}</div>
                      {% endif %}
                      {% if news_items %}
                      {% for item in news_items %}
                      <div style="padding:12px 0 0 0;{% if not loop.first %}border-top:1px solid #e2e8f0;margin-top:12px;{% endif %}">
                        <div class="text-strong news-headline" style="font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#0f172a;font-size:20px;line-height:1.5;font-weight:800;">{{ item.headline }}</div>
                        {% if item.market_meaning %}
                        <div class="text-body" style="padding-top:8px;font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#334155;font-size:16px;line-height:1.6;">{{ item.market_meaning }}</div>
                        {% endif %}
                        {% if item.korea_takeaway %}
                        <div class="text-subtle" style="padding-top:8px;font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#475569;font-size:13px;line-height:1.4;font-weight:700;">국내 투자자 관점</div>
                        <div class="text-body" style="padding-top:4px;font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#64748b;font-size:13px;line-height:1.6;">{{ item.korea_takeaway }}</div>
                        {% endif %}
                      </div>
                      {% endfor %}
                      {% else %}
                      <div class="text-body" style="padding-top:14px;font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#334155;font-size:16px;line-height:1.6;white-space:pre-line;">{{ news_fallback_text }}</div>
                      {% endif %}
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
            {% endif %}

            {# ── ③ 시장 흐름 카드 ── #}
            {% if stock_rows or stock_fallback_text %}
            <tr>
              <td style="padding:0 0 14px 0;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="card" style="width:100%;background:#ffffff;border:1px solid #e2e8f0;border-radius:16px;box-shadow:0 2px 8px rgba(15,23,42,0.04);">
                  <tr>
                    <td class="card-pad" style="padding:22px;">
                      <div class="text-subtle" style="font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#0f766e;font-size:13px;line-height:1.4;font-weight:600;">📊 시장 흐름</div>
                      {% if stock_rows %}
                      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="padding-top:12px;">
                        {% if stock_up_rows %}
                        <tr>
                          <td class="text-subtle" style="padding:12px 0 4px 0;font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#16a34a;font-size:13px;line-height:1.4;font-weight:700;">🟢 상승</td>
                        </tr>
                        {% for row in stock_up_rows %}
                        <tr>
                          <td class="text-body" style="padding:10px 0;border-top:1px solid #e2e8f0;vertical-align:top;font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#334155;font-size:16px;line-height:1.6;font-variant-numeric:tabular-nums;">{{ row.context_html }}</td>
                        </tr>
                        {% endfor %}
                        {% endif %}
                        {% if stock_down_rows %}
                        <tr>
                          <td class="text-subtle" style="padding:{% if stock_up_rows %}16{% else %}12{% endif %}px 0 4px 0;font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#dc2626;font-size:13px;line-height:1.4;font-weight:700;">🔴 하락</td>
                        </tr>
                        {% for row in stock_down_rows %}
                        <tr>
                          <td class="text-body" style="padding:10px 0;border-top:1px solid #e2e8f0;vertical-align:top;font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#334155;font-size:16px;line-height:1.6;font-variant-numeric:tabular-nums;">{{ row.context_html }}</td>
                        </tr>
                        {% endfor %}
                        {% endif %}
                      </table>
                      {% else %}
                      <div class="text-body" style="padding-top:14px;font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#334155;font-size:16px;line-height:1.6;white-space:pre-line;">{{ stock_fallback_text }}</div>
                      {% endif %}
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
            {% endif %}

            {# ── ④ 거시 지표 카드 (서브 카드) ── #}
            {% if macro_rows or footer_notes %}
            <tr>
              <td style="padding:0 0 14px 0;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="card section-fill" style="width:100%;background:#eeeee8;border:1px solid #e2e8f0;border-radius:16px;box-shadow:none;">
                  <tr>
                    <td class="card-pad" style="padding:22px;">
                      <div class="text-subtle" style="font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#475569;font-size:13px;line-height:1.4;font-weight:600;">🔢 거시 지표</div>
                      {% if macro_rows %}
                      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="padding-top:10px;">
                        {% for label, value in macro_rows %}
                        <tr>
                          <td style="padding:10px 12px 10px 0;border-top:1px solid #e2e8f0;width:28%;vertical-align:top;font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#475569;font-size:13px;line-height:1.6;font-weight:700;">{{ label }}</td>
                          <td class="text-body" style="padding:10px 0;border-top:1px solid #e2e8f0;vertical-align:top;font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#334155;font-size:16px;line-height:1.6;font-variant-numeric:tabular-nums;">{{ value }}</td>
                        </tr>
                        {% endfor %}
                      </table>
                      {% endif %}
                      {% if footer_notes %}
                      <div style="padding-top:14px;">
                        <div class="text-subtle" style="font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#92400e;font-size:12px;line-height:1.4;font-weight:700;">데이터 처리 메모</div>
                        <ul style="margin:10px 0 0 0;padding:0;list-style:none;">
                          {% for note in footer_notes %}
                          <li style="margin:0 0 8px 0;padding:0;font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#475569;font-size:13px;line-height:1.7;">{{ note }}</li>
                          {% endfor %}
                        </ul>
                      </div>
                      {% endif %}
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
            {% endif %}

            {# ── ⑤ 체크포인트 카드 (신규) ── #}
            {% if watch_items %}
            <tr>
              <td style="padding:0 0 14px 0;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="card watch-accent" style="width:100%;background:#ffffff;border:1px solid #e2e8f0;border-left:4px solid #7c3aed;border-radius:0 16px 16px 0;box-shadow:0 2px 8px rgba(15,23,42,0.04);">
                  <tr>
                    <td class="card-pad" style="padding:22px;">
                      <div class="text-subtle" style="font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#7c3aed;font-size:13px;line-height:1.4;font-weight:600;">🎯 오늘 체크할 포인트</div>
                      <ul style="margin:10px 0 0 0;padding:0;list-style:none;">
                        {% for item in watch_items %}
                        <li class="text-body" style="margin:0 0 8px 0;padding:0;font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#334155;font-size:16px;line-height:1.6;">· {{ item }}</li>
                        {% endfor %}
                      </ul>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
            {% endif %}

            {# ── ⑥ 데이터 출처 카드 ── #}
            <tr>
              <td style="padding:0 0 14px 0;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="card" style="width:100%;background:#ffffff;border:1px solid #e2e8f0;border-radius:16px;box-shadow:0 2px 8px rgba(15,23,42,0.04);">
                  <tr>
                    <td class="card-pad" style="padding:20px 22px;">
                      <div class="text-subtle" style="font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#475569;font-size:13px;line-height:1.4;font-weight:600;">📎 데이터 출처</div>
                      {% if news_source_items %}
                      <div style="padding-top:14px;">
                        <div class="text-strong" style="font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#0f172a;font-size:13px;line-height:1.5;font-weight:800;">뉴스</div>
                        {% for item in news_source_items %}
                        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="source-row" style="padding-top:10px;">
                          <tr>
                            <td class="text-body text-link" style="font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#334155;font-size:14px;line-height:1.6;">
                              {% if item.safe_url %}
                              <a href="{{ item.safe_url }}" style="color:#334155;text-decoration:none;font-weight:600;">· {{ item.headline }}</a>
                              {% else %}
                              · {{ item.headline }}
                              {% endif %}
                            </td>
                            <td class="source-name" align="right" style="font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#64748b;font-size:12px;line-height:1.6;font-weight:600;white-space:nowrap;">{{ item.source_name }}</td>
                          </tr>
                        </table>
                        {% endfor %}
                      </div>
                      {% endif %}
                      <div style="padding-top:14px;">
                        <div class="text-strong" style="font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#0f172a;font-size:13px;line-height:1.5;font-weight:800;">시장 데이터</div>
                        {% for line in market_source_lines %}
                        <div class="text-body" style="padding-top:10px;font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#334155;font-size:14px;line-height:1.6;">· {{ line }}</div>
                        {% endfor %}
                      </div>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            {# ── 면책/구독해지/GitHub ── #}
            <tr>
              <td class="text-muted" style="padding:6px 8px 0 8px;font-family:'Apple SD Gothic Neo','Noto Sans KR',-apple-system,BlinkMacSystemFont,'Malgun Gothic','Segoe UI',Roboto,sans-serif;color:#64748b;font-size:12px;line-height:1.8;text-align:center;">
                본 메일은 공개 시장 데이터와 외부 출처를 바탕으로 작성한 정보성 브리핑입니다. 투자 권유나 자문이 아닙니다.<br>
                <a href="{{ unsubscribe_url }}" class="footer-link" style="color:#64748b;text-decoration:underline;">구독 해지</a>
                ·
                <a href="{{ github_url }}" class="footer-link" style="color:#64748b;text-decoration:underline;">GitHub</a>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
