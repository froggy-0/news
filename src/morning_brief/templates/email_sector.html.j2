{% from "email_macros.html.j2" import section_label with context %}
<tr data-mail-rhythm="data"><td style="padding:0;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
<tr>
<td class="section-pad" style="padding:{{ mail_theme.spacing.sectionGap }} {{ mail_theme.spacing.shellX }};border-bottom:1px solid {{ mail_theme.colors.border }};">
{{ section_label("오늘 주목 흐름", "green") }}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:18px;">
<tr>
<td class="stack-col stack-col-left panel panel-strong" valign="top" style="width:33.333%;padding:16px;background:{{ mail_theme.colors.panelBgStrong }};border:1px solid {{ mail_theme.colors.border }};">
{{ section_label("상단 수혜", "green") }}
{% for item in sector_mapping.positive %}
<div class="text-body" style="padding-top:10px;font-family:{{ mail_theme.typography.bodySans }};color:{{ mail_theme.colors.textBody }};font-size:13px;line-height:1.8;"><span class="text-strong" style="color:{{ mail_theme.colors.textStrong }};font-weight:800;">{{ item.ticker }}</span> {{ item.reason }}</div>
{% endfor %}
</td>
<td class="stack-col panel" valign="top" style="width:33.333%;padding:16px;background:{{ mail_theme.colors.panelBg }};border:1px solid {{ mail_theme.colors.border }};border-left:none;">
{{ section_label("하단 압력", "cyan") }}
{% for item in sector_mapping.negative %}
<div class="text-body" style="padding-top:10px;font-family:{{ mail_theme.typography.bodySans }};color:{{ mail_theme.colors.textBody }};font-size:13px;line-height:1.8;"><span class="text-strong" style="color:{{ mail_theme.colors.textStrong }};font-weight:800;">{{ item.ticker }}</span> {{ item.reason }}</div>
{% endfor %}
</td>
<td class="stack-col stack-col-right panel panel-strong" valign="top" style="width:33.333%;padding:16px;background:{{ mail_theme.colors.panelBgStrong }};border:1px solid {{ mail_theme.colors.border }};border-left:none;">
{{ section_label("중립 관망", "green") }}
{% for item in sector_mapping.neutral %}
<div class="text-body" style="padding-top:10px;font-family:{{ mail_theme.typography.bodySans }};color:{{ mail_theme.colors.textBody }};font-size:13px;line-height:1.8;"><span class="text-strong" style="color:{{ mail_theme.colors.textStrong }};font-weight:800;">{{ item.ticker }}</span> {{ item.reason }}</div>
{% endfor %}
</td>
</tr>
</table>
{% if sector_mapping.commentary %}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="panel" style="margin-top:16px;background:{{ mail_theme.colors.panelBg }};border:1px solid {{ mail_theme.colors.border }};">
<tr>
<td class="text-muted" style="padding:14px 16px;font-family:{{ mail_theme.typography.bodySans }};color:{{ mail_theme.colors.textMuted }};font-size:13px;line-height:1.82;">{{ sector_mapping.commentary }}</td>
</tr>
</table>
{% endif %}
</td></tr>
</table>
</td></tr>
