{# 변수: sector_mapping (SectorMapping) #}
{% from "email_macros.html.j2" import section_label %}
<tr><td style="padding:0;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
<tr>
<td class="section-pad" style="padding:34px 40px 36px 40px;border-bottom:1px solid #1c1b1b;">
{{ section_label("오늘 주목 흐름", "#02e600") }}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="padding-top:10px;">
<tr>
<td class="stack-col stack-col-left" valign="top" style="width:33.333%;padding:0 14px 0 0;">
<div style="font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#7ef466;font-size:10px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;">상단 수혜</div>
{% for item in sector_mapping.positive %}
<div style="padding-top:10px;font-family:'Apple SD Gothic Neo','Noto Sans KR','Malgun Gothic',sans-serif;color:#c6c6c6;font-size:13px;line-height:1.8;" class="text-body"><span style="color:#ffffff;font-weight:700;" class="text-strong">{{ item.ticker }}</span> {{ item.reason }}</div>
{% endfor %}
</td>
<td class="stack-col" valign="top" style="width:33.333%;padding:0 14px;border-left:1px solid #1c1b1b;">
<div style="font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#f4a4a4;font-size:10px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;">하단 압력</div>
{% for item in sector_mapping.negative %}
<div style="padding-top:10px;font-family:'Apple SD Gothic Neo','Noto Sans KR','Malgun Gothic',sans-serif;color:#c6c6c6;font-size:13px;line-height:1.8;" class="text-body"><span style="color:#ffffff;font-weight:700;" class="text-strong">{{ item.ticker }}</span> {{ item.reason }}</div>
{% endfor %}
</td>
<td class="stack-col stack-col-right" valign="top" style="width:33.333%;padding:0 0 0 14px;border-left:1px solid #1c1b1b;">
<div style="font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#b1b1b1;font-size:10px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;">중립 관망</div>
{% for item in sector_mapping.neutral %}
<div style="padding-top:10px;font-family:'Apple SD Gothic Neo','Noto Sans KR','Malgun Gothic',sans-serif;color:#c6c6c6;font-size:13px;line-height:1.8;" class="text-body"><span style="color:#ffffff;font-weight:700;" class="text-strong">{{ item.ticker }}</span> {{ item.reason }}</div>
{% endfor %}
</td>
</tr>
</table>
{% if sector_mapping.commentary %}
<div style="padding-top:18px;border-top:1px solid #1c1b1b;margin-top:18px;font-family:'Apple SD Gothic Neo','Noto Sans KR','Malgun Gothic',sans-serif;color:#888888;font-size:13px;line-height:1.8;" class="text-muted">{{ sector_mapping.commentary }}</div>
{% endif %}
</td></tr>
</table>
</td></tr>
