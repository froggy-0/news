{# 변수: hero_summary, hero_alerts #}
<tr><td style="padding:0 0 24px 0;">
<table role="presentation" width="100%" class="card" style="width:100%;background:#fff;border:1px solid #e2e8f0;border-top:4px solid #1e40af;border-radius:0 0 16px 16px;">
<tr><td class="card-pad" style="padding:28px 24px;">
<div style="border-left:3px solid #1e40af;padding-left:12px;font-family:'Apple SD Gothic Neo','Noto Sans KR',sans-serif;color:#1e40af;font-size:13px;font-weight:600;">&#9632; &#xC624;&#xB298;&#xC758; &#xD575;&#xC2EC;</div>
<div class="hero-box" style="margin-top:16px;background:#f0f4ff;padding:20px;border-radius:8px;">
<div class="hero-title text-strong" style="font-family:'Apple SD Gothic Neo','Noto Sans KR',sans-serif;color:#0f172a;font-size:32px;line-height:1.5;font-weight:800;letter-spacing:-0.03em;white-space:pre-line;">{{ hero_summary }}</div>
</div>
{% if hero_alerts %}
<div style="padding-top:16px;">
{% for alert in hero_alerts %}
<div style="padding-top:8px;font-family:'Apple SD Gothic Neo','Noto Sans KR',sans-serif;color:#475569;font-size:14px;line-height:1.8;" class="text-body">&#9679; {{ alert }}</div>
{% endfor %}
</div>
{% endif %}
</td></tr>
</table>
</td></tr>
