{% macro eyebrow(text, accent='muted') -%}
<div style="font-family:{{ mail_theme.typography.labelMono }};color:{% if accent == 'green' %}{{ mail_theme.colors.accentGreen }}{% elif accent == 'cyan' %}{{ mail_theme.colors.accentCyan }}{% else %}{{ mail_theme.colors.textMuted }}{% endif %};font-size:10px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;">
  {{ text }}
</div>
{%- endmacro %}

{% macro section_label(text, accent='green') -%}
<div style="font-family:{{ mail_theme.typography.labelMono }};color:{% if accent == 'cyan' %}{{ mail_theme.colors.accentCyan }}{% else %}{{ mail_theme.colors.accentGreen }}{% endif %};font-size:10px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;">
  {{ text }}
</div>
{%- endmacro %}

{% macro signal_pill(text, tone='flat', href=None) -%}
{% set border = mail_theme.colors.border %}
{% set background = mail_theme.colors.badgeFlatBg %}
{% set color = mail_theme.colors.accentNeutral %}
{% if tone == 'up' %}
  {% set border = mail_theme.colors.accentGreen %}
  {% set background = mail_theme.colors.badgeUpBg %}
  {% set color = mail_theme.colors.accentGreen %}
{% elif tone == 'down' %}
  {% set border = mail_theme.colors.accentDown %}
  {% set background = mail_theme.colors.badgeDownBg %}
  {% set color = mail_theme.colors.accentDown %}
{% elif tone == 'cyan' %}
  {% set border = mail_theme.colors.accentCyan %}
  {% set background = mail_theme.colors.panelBgStrong %}
  {% set color = mail_theme.colors.accentCyan %}
{% endif %}
{% set pill_style -%}
display:inline-block;border:1px solid {{ border }};background:{{ background }};color:{{ color }};border-radius:{{ mail_theme.components.pill.radius }};padding:{{ mail_theme.components.pill.padding }};font-family:{{ mail_theme.typography.labelMono }};font-size:{{ mail_theme.components.pill.fontSize }};font-weight:700;letter-spacing:{{ mail_theme.components.pill.letterSpacing }};text-transform:uppercase;text-decoration:none;
{%- endset %}
{% if href %}
<a href="{{ href }}" style="{{ pill_style|trim }}">{{ text }}</a>
{% else %}
<span style="{{ pill_style|trim }}">{{ text }}</span>
{% endif %}
{%- endmacro %}

{% macro delta_badge(value, direction) -%}
{% set border = mail_theme.colors.border %}
{% set background = mail_theme.colors.badgeFlatBg %}
{% set color = mail_theme.colors.accentNeutral %}
{% set symbol = '&#8212;' %}
{% set klass = 'badge-flat' %}
{% if direction == 'up' %}
  {% set border = mail_theme.colors.accentGreen %}
  {% set background = mail_theme.colors.badgeUpBg %}
  {% set color = mail_theme.colors.accentGreen %}
  {% set symbol = '&#9650;' %}
  {% set klass = 'badge-up' %}
{% elif direction == 'down' %}
  {% set border = mail_theme.colors.accentDown %}
  {% set background = mail_theme.colors.badgeDownBg %}
  {% set color = mail_theme.colors.accentDown %}
  {% set symbol = '&#9660;' %}
  {% set klass = 'badge-down' %}
{% endif %}
<span class="{{ klass }}" style="display:inline-block;border:1px solid {{ border }};background:{{ background }};color:{{ color }};border-radius:{{ mail_theme.components.badge.radius }};padding:{{ mail_theme.components.badge.padding }};font-family:{{ mail_theme.typography.labelMono }};font-size:{{ mail_theme.components.badge.fontSize }};font-weight:700;font-variant-numeric:tabular-nums;white-space:nowrap;letter-spacing:0.02em;">{{ symbol|safe }} {{ value }}</span>
{%- endmacro %}

{% macro utility_link(text, href) -%}
<a href="{{ href }}" style="color:{{ mail_theme.colors.textMuted }};font-family:{{ mail_theme.typography.labelMono }};font-size:{{ mail_theme.components.footerLink.fontSize }};letter-spacing:{{ mail_theme.components.footerLink.letterSpacing }};text-transform:uppercase;text-decoration:none;">{{ text }}</a>
{%- endmacro %}

{% macro cta_button(text, href) -%}
<a href="{{ href }}" style="display:inline-block;min-height:{{ mail_theme.layout.ctaMinHeight }};padding:{{ mail_theme.components.cta.padding }};border-radius:{{ mail_theme.components.cta.radius }};border:1px solid {{ mail_theme.components.cta.accentBorder }};background:{{ mail_theme.components.cta.background }};color:{{ mail_theme.components.cta.text }};font-family:{{ mail_theme.typography.bodySans }};font-size:14px;font-weight:800;line-height:1.2;text-decoration:none;">{{ text }}</a>
{%- endmacro %}
