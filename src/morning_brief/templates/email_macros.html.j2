{# 컬러 배지 매크로 — 모든 파셜에서 import하여 사용 #}
{% macro badge(value, direction) %}
<span style="display:inline-block;background:{% if direction == 'up' %}#142313{% elif direction == 'down' %}#2a1717{% else %}#151515{% endif %};border:1px solid {% if direction == 'up' %}#244322{% elif direction == 'down' %}#4d2626{% else %}#2b2b2b{% endif %};color:{% if direction == 'up' %}#7ef466{% elif direction == 'down' %}#f4a4a4{% else %}#b1b1b1{% endif %};padding:3px 8px;border-radius:999px;font-size:11px;font-weight:700;font-variant-numeric:tabular-nums;white-space:nowrap;letter-spacing:0.02em;" class="{% if direction == 'up' %}badge-up{% elif direction == 'down' %}badge-down{% else %}badge-flat{% endif %}">{% if direction == 'up' %}&#9650;{% elif direction == 'down' %}&#9660;{% else %}&#8212;{% endif %} {{ value }}</span>
{% endmacro %}

{# KR 라벨 매크로 #}
{% macro kr_label() %}
<span class="kr-label" style="display:inline-block;border:1px solid #166534;border-radius:3px;padding:1px 5px;color:#166534;font-size:11px;font-weight:700;">KR</span>
{% endmacro %}

{# 섹션 라벨 매크로 #}
{% macro section_label(text, color) %}
<div style="font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:{{ color }};font-size:11px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;">{{ text }}</div>
{% endmacro %}

{# 데이터 품질 인라인 마크 #}
{% macro quality_mark(text) %}
<span style="font-size:11px;color:#94a3b8;">({{ text }})</span>
{% endmacro %}

{% macro delta_text(value, direction) %}
<span style="font-family:'SFMono-Regular','Menlo','Consolas',monospace;font-size:11px;font-weight:700;color:{% if direction == 'up' %}#7ef466{% elif direction == 'down' %}#f4a4a4{% else %}#b1b1b1{% endif %};letter-spacing:0.02em;">
{% if direction == 'up' %}&#9650;{% elif direction == 'down' %}&#9660;{% else %}&#8212;{% endif %} {{ value }}
</span>
{% endmacro %}

{% macro pill(text, tone='flat', href=None) %}
{% if href %}
<a href="{{ href }}" style="display:inline-block;padding:5px 9px;border-radius:999px;border:1px solid {% if tone == 'up' %}#244322{% elif tone == 'down' %}#4d2626{% else %}#2b2b2b{% endif %};background:{% if tone == 'up' %}#142313{% elif tone == 'down' %}#2a1717{% else %}#151515{% endif %};color:{% if tone == 'up' %}#7ef466{% elif tone == 'down' %}#f4a4a4{% else %}#d9d9d9{% endif %};font-size:10px;font-weight:700;text-decoration:none;letter-spacing:0.12em;text-transform:uppercase;">{{ text }}</a>
{% else %}
<span style="display:inline-block;padding:5px 9px;border-radius:999px;border:1px solid {% if tone == 'up' %}#244322{% elif tone == 'down' %}#4d2626{% else %}#2b2b2b{% endif %};background:{% if tone == 'up' %}#142313{% elif tone == 'down' %}#2a1717{% else %}#151515{% endif %};color:{% if tone == 'up' %}#7ef466{% elif tone == 'down' %}#f4a4a4{% else %}#d9d9d9{% endif %};font-size:10px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;">{{ text }}</span>
{% endif %}
{% endmacro %}
