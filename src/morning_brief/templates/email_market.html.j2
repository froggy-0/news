{# 변수: stock_indices, stock_tech, macro_indicators, market_status_text #}
{% from "email_macros.html.j2" import badge, quality_mark, section_label %}
<tr><td style="padding:0;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
<tr>
<td class="section-pad" style="padding:34px 40px 36px 40px;border-bottom:1px solid #1c1b1b;">
{{ section_label("미국 증시 흐름", "#02e600") }}
{% if not stock_indices and not stock_tech and not macro_indicators %}
<div style="padding-top:18px;font-family:'Apple SD Gothic Neo','Noto Sans KR','Malgun Gothic',sans-serif;color:#888888;font-size:15px;line-height:1.9;" class="text-muted">{{ market_status_text or "이번 집계에서는 시장 지표를 확인하지 못했어요." }}</div>
{% endif %}

{% if stock_indices %}
<div style="padding-top:22px;font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#888888;font-size:10px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;" class="text-muted">주요 지수</div>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="padding-top:8px;">
{% for s in stock_indices %}
<tr>
<td style="padding:14px 0;border-top:1px solid #1c1b1b;font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#ffffff;font-size:13px;font-weight:700;" class="text-strong">{{ s.ticker }}</td>
<td style="padding:14px 12px;border-top:1px solid #1c1b1b;font-family:'Apple SD Gothic Neo','Noto Sans KR','Malgun Gothic',sans-serif;color:#888888;font-size:13px;line-height:1.7;" class="text-muted">{{ s.name }}</td>
<td align="right" style="padding:14px 0;border-top:1px solid #1c1b1b;font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#ffffff;font-size:14px;font-weight:700;font-variant-numeric:tabular-nums;" class="text-strong">{{ s.price }}</td>
<td align="right" style="padding:14px 0 14px 12px;border-top:1px solid #1c1b1b;">{{ badge(s.change_pct, s.direction) }}</td>
</tr>
{% endfor %}
</table>
{% endif %}

{% if stock_tech %}
<div style="padding-top:24px;font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#888888;font-size:10px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;" class="text-muted">주요 기술주</div>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="padding-top:8px;">
{% for s in stock_tech %}
<tr>
<td style="padding:12px 0;border-top:1px solid #1c1b1b;font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#ffffff;font-size:13px;font-weight:700;" class="text-strong">{{ s.ticker }}</td>
<td align="right" style="padding:12px 0;border-top:1px solid #1c1b1b;">{{ badge(s.change_pct, s.direction) }}</td>
</tr>
{% endfor %}
</table>
{% endif %}

{% if macro_indicators %}
<div style="padding-top:24px;font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#888888;font-size:10px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;" class="text-muted">거시 환경</div>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="padding-top:8px;">
{% for m in macro_indicators %}
<tr>
<td style="padding:14px 0;border-top:1px solid #1c1b1b;font-family:'Apple SD Gothic Neo','Noto Sans KR','Malgun Gothic',sans-serif;color:#ffffff;font-size:14px;font-weight:700;" class="text-strong">{{ m.label }}</td>
<td align="right" style="padding:14px 0;border-top:1px solid #1c1b1b;font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#ffffff;font-size:14px;font-weight:700;font-variant-numeric:tabular-nums;" class="text-strong">
{% if m.is_anomaly %}
<span class="text-muted" style="color:#888888;font-family:'Apple SD Gothic Neo','Noto Sans KR','Malgun Gothic',sans-serif;font-size:13px;line-height:1.7;">{{ m.status_text or "이번 집계에서는 확인되지 않았어요." }}</span>
{% else %}
{{ m.value }}{% if m.is_previous %} {{ quality_mark("전일") }}{% endif %}
{% endif %}
</td>
<td align="right" style="padding:14px 0 14px 12px;border-top:1px solid #1c1b1b;">{% if not m.is_anomaly and m.change %}{{ badge(m.change, m.direction) }}{% endif %}</td>
</tr>
{% endfor %}
</table>
{% endif %}
</td>
</tr>
</table>
</td></tr>
