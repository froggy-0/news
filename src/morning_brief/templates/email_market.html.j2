{% from "email_macros.html.j2" import delta_badge, section_label with context %}
<tr data-mail-rhythm="data"><td style="padding:0;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
<tr>
<td class="section-pad" style="padding:{{ mail_theme.spacing.sectionGap }} {{ mail_theme.spacing.shellX }};border-bottom:1px solid {{ mail_theme.colors.border }};">
{{ section_label("크립토 외부환경", "green") }}
{% if not stock_indices and not stock_tech and not macro_indicators %}
<div class="text-muted" style="padding-top:18px;font-family:{{ mail_theme.typography.bodySans }};color:{{ mail_theme.colors.textMuted }};font-size:15px;line-height:1.9;">
  {{ market_status_text or "이번 집계에서는 시장 지표를 확인하지 못했어요." }}
</div>
{% endif %}

{% if macro_indicators %}
<div style="padding-top:20px;">{{ section_label("크립토 돈 흐름", "cyan") }}</div>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="panel panel-strong" style="margin-top:8px;background:{{ mail_theme.colors.panelBgStrong }};border:1px solid {{ mail_theme.colors.border }};">
{% for m in macro_indicators %}
<tr>
<td class="text-strong" style="padding:14px 16px;border-top:{% if loop.first %}0{% else %}1px solid {{ mail_theme.colors.border }}{% endif %};font-family:{{ mail_theme.typography.bodySans }};color:{{ mail_theme.colors.textStrong }};font-size:14px;font-weight:800;">{{ m.label }}</td>
<td align="right" class="text-body" style="padding:14px 0;border-top:{% if loop.first %}0{% else %}1px solid {{ mail_theme.colors.border }}{% endif %};font-family:{{ mail_theme.typography.bodySans }};color:{{ mail_theme.colors.textBody }};font-size:13px;line-height:1.75;">
{% if m.is_anomaly %}
{{ m.status_text or "이번 집계에서는 확인되지 않았어요." }}
{% else %}
{{ m.value }}
{% endif %}
</td>
<td align="right" style="padding:14px 16px 14px 12px;border-top:{% if loop.first %}0{% else %}1px solid {{ mail_theme.colors.border }}{% endif %};">{% if not m.is_anomaly and m.change %}{{ delta_badge(m.change, m.direction) }}{% endif %}</td>
</tr>
{% endfor %}
</table>
{% endif %}

{% if stock_indices %}
<div style="padding-top:24px;">{{ section_label("주요 지수", "cyan") }}</div>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="padding-top:8px;">
{% for s in stock_indices %}
<tr>
<td style="padding:14px 0;border-top:1px solid {{ mail_theme.colors.border }};font-family:{{ mail_theme.typography.labelMono }};color:{{ mail_theme.colors.textMuted }};font-size:11px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;" class="text-muted">{{ s.ticker }}</td>
<td class="text-body" style="padding:14px 12px;border-top:1px solid {{ mail_theme.colors.border }};font-family:{{ mail_theme.typography.bodySans }};color:{{ mail_theme.colors.textBody }};font-size:13px;line-height:1.7;">{{ s.name }}</td>
<td align="right" class="text-strong" style="padding:14px 0;border-top:1px solid {{ mail_theme.colors.border }};font-family:{{ mail_theme.typography.bodySans }};color:{{ mail_theme.colors.textStrong }};font-size:14px;font-weight:800;letter-spacing:-0.02em;">{{ s.price }}</td>
<td align="right" style="padding:14px 0 14px 12px;border-top:1px solid {{ mail_theme.colors.border }};">{{ delta_badge(s.change_pct, s.direction) }}</td>
</tr>
{% endfor %}
</table>
{% endif %}

{% if stock_tech %}
<div style="padding-top:24px;">{{ section_label("크립토 관련 종목", "green") }}</div>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="padding-top:8px;">
{% for s in stock_tech %}
<tr>
<td style="padding:12px 0;border-top:1px solid {{ mail_theme.colors.border }};font-family:{{ mail_theme.typography.labelMono }};color:{{ mail_theme.colors.textMuted }};font-size:11px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;" class="text-muted">{{ s.ticker }}</td>
<td class="text-body" style="padding:12px 12px;border-top:1px solid {{ mail_theme.colors.border }};font-family:{{ mail_theme.typography.bodySans }};color:{{ mail_theme.colors.textBody }};font-size:13px;line-height:1.7;">{{ s.name }}</td>
<td align="right" style="padding:12px 0;border-top:1px solid {{ mail_theme.colors.border }};">{{ delta_badge(s.change_pct, s.direction) }}</td>
</tr>
{% endfor %}
</table>
{% endif %}
</td>
</tr>
</table>
</td></tr>
