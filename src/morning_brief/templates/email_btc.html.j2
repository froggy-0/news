{# 변수: btc_data (BTCData) #}
{% from "email_macros.html.j2" import badge, section_label %}
<tr><td style="padding:0;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
<tr>
<td class="section-pad" style="padding:34px 40px 36px 40px;border-bottom:1px solid #1c1b1b;">
{{ section_label("비트코인과 ETF", "#02e600") }}
{% if btc_data.status_text %}
<div style="padding-top:18px;font-family:'Apple SD Gothic Neo','Noto Sans KR','Malgun Gothic',sans-serif;color:#888888;font-size:15px;line-height:1.9;" class="text-muted">{{ btc_data.status_text }}</div>
{% endif %}

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="padding-top:18px;">
<tr>
<td class="stack-col stack-col-left" valign="top" style="width:58%;padding:0 14px 0 0;">
<div style="font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#888888;font-size:10px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;" class="text-muted">BTC 현물</div>
<div style="padding-top:10px;font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#ffffff;font-size:30px;font-weight:700;line-height:1.1;font-variant-numeric:tabular-nums;" class="text-strong">{{ btc_data.spot_price }}</div>
{% if btc_data.spot_change %}
<div style="padding-top:10px;">{{ badge(btc_data.spot_change, btc_data.spot_direction) }}</div>
{% endif %}
</td>
<td class="stack-col stack-col-right" valign="top" style="width:42%;padding:0 0 0 14px;border-left:1px solid #1c1b1b;">
<div style="font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#888888;font-size:10px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;" class="text-muted">공포탐욕지수</div>
<div style="padding-top:10px;font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#ffffff;font-size:28px;font-weight:700;line-height:1.1;font-variant-numeric:tabular-nums;" class="text-strong">{{ btc_data.fear_greed_value }}/100</div>
<div style="padding-top:8px;font-family:'Apple SD Gothic Neo','Noto Sans KR','Malgun Gothic',sans-serif;color:#c6c6c6;font-size:14px;line-height:1.8;" class="text-body">{{ btc_data.fear_greed_label }}</div>
</td>
</tr>
</table>

{% if btc_data.etf_items %}
<div style="padding-top:24px;font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#888888;font-size:10px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;" class="text-muted">주요 현물 ETF</div>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="padding-top:8px;">
{% for etf in btc_data.etf_items %}
<tr>
<td style="padding:12px 0;border-top:1px solid #1c1b1b;font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#ffffff;font-size:13px;font-weight:700;" class="text-strong">{{ etf.ticker }}</td>
<td align="right" style="padding:12px 0;border-top:1px solid #1c1b1b;font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#ffffff;font-size:13px;font-weight:700;font-variant-numeric:tabular-nums;" class="text-strong">${{ etf.price }}</td>
<td align="right" style="padding:12px 0 12px 12px;border-top:1px solid #1c1b1b;">{{ badge(etf.change_pct|default('0%'), etf.direction|default('flat')) }}</td>
</tr>
{% endfor %}
</table>
{% endif %}

{% if btc_data.official_snapshots %}
<div style="padding-top:24px;font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#888888;font-size:10px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;" class="text-muted">기관 보유 현황</div>
{% if btc_data.official_total_btc or btc_data.official_total_aum %}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="padding-top:8px;">
<tr>
{% if btc_data.official_total_btc %}
<td class="stack-col stack-col-left" valign="top" style="width:50%;padding:12px 14px 0 0;border-top:1px solid #1c1b1b;">
<div style="font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#888888;font-size:10px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;" class="text-muted">총 BTC 보유량</div>
<div style="padding-top:8px;font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#ffffff;font-size:18px;font-weight:700;font-variant-numeric:tabular-nums;" class="text-strong">{{ btc_data.official_total_btc }}</div>
</td>
{% endif %}
{% if btc_data.official_total_aum %}
<td class="stack-col stack-col-right" valign="top" style="width:50%;padding:12px 0 0 14px;border-top:1px solid #1c1b1b;{% if btc_data.official_total_btc %}border-left:1px solid #1c1b1b;{% endif %}">
<div style="font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#888888;font-size:10px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;" class="text-muted">총 AUM</div>
<div style="padding-top:8px;font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#ffffff;font-size:18px;font-weight:700;font-variant-numeric:tabular-nums;" class="text-strong">{{ btc_data.official_total_aum }}</div>
</td>
{% endif %}
</tr>
</table>
{% endif %}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="padding-top:8px;">
{% for snap in btc_data.official_snapshots %}
<tr>
<td style="padding:12px 0;border-top:1px solid #1c1b1b;font-family:'Apple SD Gothic Neo','Noto Sans KR','Malgun Gothic',sans-serif;color:#ffffff;font-size:14px;font-weight:700;" class="text-strong">{{ snap.issuer }} {{ snap.ticker }}</td>
<td align="right" style="padding:12px 0;border-top:1px solid #1c1b1b;font-family:'Apple SD Gothic Neo','Noto Sans KR','Malgun Gothic',sans-serif;color:#c6c6c6;font-size:13px;line-height:1.8;" class="text-body">{{ snap.btc_held }} BTC &#183; AUM {{ snap.aum }}</td>
</tr>
{% endfor %}
</table>
{% endif %}
</td>
</tr>
</table>
</td></tr>
