<!doctype html>
<html lang="ko">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<meta name="color-scheme" content="light dark">
<title>{{ subject }}</title>
<!--[if mso]><style>
.shell{background:#0e0e0e!important}
.container{background:#0e0e0e!important}
</style><![endif]-->
<style>
body,.shell,.container{background:#0e0e0e!important}
.card{background:#0e0e0e!important}
.section-rule{border-color:#1c1b1b!important}
.text-strong{color:#ffffff!important}
.text-body{color:#c6c6c6!important}
.text-muted{color:#888888!important}
.accent{color:#02e600!important}
.badge-up{background:#142313!important;color:#7ef466!important}
.badge-down{background:#2a1717!important;color:#f4a4a4!important}
.badge-flat{background:#151515!important;color:#b1b1b1!important}
a{color:#ffffff!important}
@media(prefers-color-scheme:dark){
body,.shell,.container{background:#0e0e0e!important}
.card{background:#0e0e0e!important}
.section-rule{border-color:#1c1b1b!important}
.text-strong{color:#ffffff!important}
.text-body{color:#c6c6c6!important}
.text-muted{color:#888888!important}
.accent{color:#02e600!important}
.badge-up{background:#142313!important;color:#7ef466!important}
.badge-down{background:#2a1717!important;color:#f4a4a4!important}
.badge-flat{background:#151515!important;color:#b1b1b1!important}
a{color:#ffffff!important}
}
@media(prefers-color-scheme:light){
body,.shell,.container{background:#0e0e0e!important}
.card{background:#0e0e0e!important}
.section-rule{border-color:#1c1b1b!important}
.text-strong{color:#ffffff!important}
.text-body{color:#c6c6c6!important}
.text-muted{color:#888888!important}
.accent{color:#02e600!important}
.badge-up{background:#142313!important;color:#7ef466!important}
.badge-down{background:#2a1717!important;color:#f4a4a4!important}
.badge-flat{background:#151515!important;color:#b1b1b1!important}
a{color:#ffffff!important}
}
@media screen and (max-width:600px){
.shell-pad{padding:12px 0!important}
.section-pad{padding-left:20px!important;padding-right:20px!important}
.headline-main{font-size:30px!important;line-height:1.05!important}
.hero-title{font-size:28px!important;line-height:1.5!important}
.meta-stack{display:block!important;width:100%!important}
.ticker-cell{display:block!important;width:100%!important;padding-right:0!important}
.ticker-row{display:block!important}
.stack-col{display:block!important;width:100%!important}
.stack-col-left{padding-right:0!important;padding-bottom:12px!important}
.stack-col-right{padding-left:0!important}
a{min-height:44px;display:inline-block;line-height:1.4}
}
</style>
</head>
<body style="margin:0;padding:0;background:#0e0e0e;">
<div style="display:none;max-height:0;overflow:hidden;">{{ preheader }}</div>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="shell" style="width:100%;background:#0e0e0e;">
<tr><td align="center" class="shell-pad" style="padding:20px 0;">
<table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" class="container" style="width:600px;max-width:600px;background:#0e0e0e;border:1px solid #1c1b1b;color:#ffffff;">
{% include "email_header.html.j2" %}
{% include "email_hero.html.j2" %}
{% include "email_news.html.j2" %}
{% include "email_market.html.j2" %}
{% include "email_btc.html.j2" %}
{% if sector_mapping %}{% include "email_sector.html.j2" %}{% endif %}
{% if event_calendar %}{% include "email_calendar.html.j2" %}{% endif %}
{% include "email_footer.html.j2" %}
</table>
</td></tr>
</table>
</body>
</html>
