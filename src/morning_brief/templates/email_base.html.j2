<!doctype html>
<html lang="ko">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<meta name="color-scheme" content="light dark">
<title>{{ subject }}</title>
<!--[if mso]><style>
.shell,.container,.panel,.panel-strong{background:{{ mail_theme.colors.shellBg }}!important}
</style><![endif]-->
<style>
body,.shell,.container{background:{{ mail_theme.colors.shellBg }}!important}
.container{border:1px solid {{ mail_theme.colors.border }}!important}
.panel{background:{{ mail_theme.colors.panelBg }}!important}
.panel-strong{background:{{ mail_theme.colors.panelBgStrong }}!important}
.section-rule{border-color:{{ mail_theme.colors.border }}!important}
.section-rule-strong{border-color:{{ mail_theme.colors.borderStrong }}!important}
.text-strong{color:{{ mail_theme.colors.textStrong }}!important}
.text-body{color:{{ mail_theme.colors.textBody }}!important}
.text-muted{color:{{ mail_theme.colors.textMuted }}!important}
.accent-green{color:{{ mail_theme.colors.accentGreen }}!important}
.accent-cyan{color:{{ mail_theme.colors.accentCyan }}!important}
.signal-rail{border-left:3px solid {{ mail_theme.colors.accentGreen }}!important}
.badge-up{background:{{ mail_theme.colors.badgeUpBg }}!important;color:{{ mail_theme.colors.accentGreen }}!important}
.badge-down{background:{{ mail_theme.colors.badgeDownBg }}!important;color:{{ mail_theme.colors.accentDown }}!important}
.badge-flat{background:{{ mail_theme.colors.badgeFlatBg }}!important;color:{{ mail_theme.colors.accentNeutral }}!important}
a{color:{{ mail_theme.colors.textStrong }}!important}
@media(prefers-color-scheme:dark){
body,.shell,.container{background:{{ mail_theme.colors.shellBg }}!important}
.container{border-color:{{ mail_theme.colors.border }}!important}
.panel{background:{{ mail_theme.colors.panelBg }}!important}
.panel-strong{background:{{ mail_theme.colors.panelBgStrong }}!important}
.section-rule{border-color:{{ mail_theme.colors.border }}!important}
.section-rule-strong{border-color:{{ mail_theme.colors.borderStrong }}!important}
.text-strong{color:{{ mail_theme.colors.textStrong }}!important}
.text-body{color:{{ mail_theme.colors.textBody }}!important}
.text-muted{color:{{ mail_theme.colors.textMuted }}!important}
.accent-green{color:{{ mail_theme.colors.accentGreen }}!important}
.accent-cyan{color:{{ mail_theme.colors.accentCyan }}!important}
a{color:{{ mail_theme.colors.textStrong }}!important}
}
@media(prefers-color-scheme:light){
body,.shell,.container{background:{{ mail_theme.colors.shellBg }}!important}
.container{border-color:{{ mail_theme.colors.border }}!important}
.panel{background:{{ mail_theme.colors.panelBg }}!important}
.panel-strong{background:{{ mail_theme.colors.panelBgStrong }}!important}
.section-rule{border-color:{{ mail_theme.colors.border }}!important}
.section-rule-strong{border-color:{{ mail_theme.colors.borderStrong }}!important}
.text-strong{color:{{ mail_theme.colors.textStrong }}!important}
.text-body{color:{{ mail_theme.colors.textBody }}!important}
.text-muted{color:{{ mail_theme.colors.textMuted }}!important}
.accent-green{color:{{ mail_theme.colors.accentGreen }}!important}
.accent-cyan{color:{{ mail_theme.colors.accentCyan }}!important}
a{color:{{ mail_theme.colors.textStrong }}!important}
}
@media screen and (max-width:600px){
.shell-pad{padding:{{ mail_theme.spacing.mobileShellY }} 0!important}
.section-pad{padding-left:{{ mail_theme.spacing.mobileShellX }}!important;padding-right:{{ mail_theme.spacing.mobileShellX }}!important}
.headline-main{font-size:30px!important;line-height:1.04!important}
.headline-serif{font-size:20px!important;line-height:1.14!important}
.hero-title{font-size:28px!important;line-height:1.26!important}
.hero-rail-pad{padding-left:18px!important}
.meta-stack{display:block!important;width:100%!important;text-align:left!important;padding-left:0!important;padding-right:0!important}
.ticker-cell{display:block!important;width:100%!important;padding-right:0!important;border-right:none!important;border-top:1px solid {{ mail_theme.colors.border }}!important}
.ticker-row{display:block!important}
.stack-col{display:block!important;width:100%!important}
.stack-col-left{padding-right:0!important;padding-bottom:14px!important}
.stack-col-right{padding-left:0!important;border-left:none!important;padding-top:14px!important}
.cta-link{min-height:{{ mail_theme.layout.ctaMinHeight }}!important;display:inline-block!important;line-height:1.4!important}
}
</style>
</head>
<body style="margin:0;padding:0;background:{{ mail_theme.colors.shellBg }};">
<div style="display:none;max-height:0;overflow:hidden;">{{ preheader }}</div>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="shell" style="width:100%;background:{{ mail_theme.colors.shellBg }};" data-mail-shell="quiet-signal">
<tr><td align="center" class="shell-pad" style="padding:20px 0;">
<table role="presentation" width="{{ mail_theme.layout.containerWidth }}" cellpadding="0" cellspacing="0" border="0" class="container" style="width:{{ mail_theme.layout.containerWidth }}px;max-width:{{ mail_theme.layout.containerWidth }}px;background:{{ mail_theme.colors.shellBg }};border:1px solid {{ mail_theme.colors.border }};color:{{ mail_theme.colors.textStrong }};" data-mail-shell="quiet-signal">
{% include "email_header.html.j2" %}
{% include "email_hero.html.j2" %}
{% include "email_news.html.j2" %}
{% include "email_market.html.j2" %}
{% include "email_btc.html.j2" %}
{% if sector_mapping %}{% include "email_sector.html.j2" %}{% endif %}
{% if event_calendar %}{% include "email_calendar.html.j2" %}{% endif %}
{% include "email_footer.html.j2" %}
</table>
</td></tr>
</table>
</body>
</html>
