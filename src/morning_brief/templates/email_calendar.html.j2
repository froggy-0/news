{% from "email_macros.html.j2" import section_label with context %}
<tr data-mail-rhythm="data"><td style="padding:0;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
<tr>
<td class="section-pad" style="padding:{{ mail_theme.spacing.sectionGap }} {{ mail_theme.spacing.shellX }};border-bottom:1px solid {{ mail_theme.colors.border }};">
{{ section_label("이번 주 일정", "green") }}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="panel panel-strong" style="margin-top:18px;background:{{ mail_theme.colors.panelBgStrong }};border:1px solid {{ mail_theme.colors.border }};">
{% for evt in event_calendar %}
<tr>
<td class="text-muted" style="padding:14px 0 14px 16px;border-top:{% if loop.first %}0{% else %}1px solid {{ mail_theme.colors.border }}{% endif %};font-family:{{ mail_theme.typography.labelMono }};color:{{ mail_theme.colors.textMuted }};font-size:11px;font-weight:700;white-space:nowrap;letter-spacing:0.1em;text-transform:uppercase;">{% if evt.is_today %}Today{% else %}{{ evt.time or evt.date }}{% endif %}</td>
<td style="padding:14px 12px;border-top:{% if loop.first %}0{% else %}1px solid {{ mail_theme.colors.border }}{% endif %};">
<div class="text-strong" style="font-family:{{ mail_theme.typography.bodySans }};color:{{ mail_theme.colors.textStrong }};font-size:14px;line-height:1.7;font-weight:{% if evt.impact >= 4 %}800{% else %}700{% endif %};">{{ evt.name }}</div>
{% if evt.expected %}
<div class="text-muted" style="padding-top:4px;font-family:{{ mail_theme.typography.bodySans }};color:{{ mail_theme.colors.textMuted }};font-size:13px;line-height:1.7;">예상치 {{ evt.expected }}</div>
{% endif %}
</td>
<td align="right" class="text-body" style="padding:14px 16px 14px 0;border-top:{% if loop.first %}0{% else %}1px solid {{ mail_theme.colors.border }}{% endif %};font-family:{{ mail_theme.typography.labelMono }};color:{{ mail_theme.colors.textBody }};font-size:12px;letter-spacing:1px;">{% for i in range(evt.impact) %}&#9632;{% endfor %}{% for i in range(5 - evt.impact) %}&#9633;{% endfor %}</td>
</tr>
{% endfor %}
</table>
</td></tr>
</table>
</td></tr>
