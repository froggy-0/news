{# 변수: news_items #}
{% from "email_macros.html.j2" import section_label %}
<tr><td style="padding:0 0 24px 0;">
<table role="presentation" width="100%" class="card" style="width:100%;background:#fff;border:1px solid #e2e8f0;border-radius:16px;">
<tr><td class="card-pad" style="padding:28px 24px;">
{{ section_label("주요 뉴스", "#1e40af") }}
{% for item in news_items %}
<div style="padding:20px 0 0 0;{% if not loop.first %}border-top:1px solid #e2e8f0;margin-top:16px;{% endif %}">
<div style="font-family:'Apple SD Gothic Neo','Noto Sans KR',sans-serif;color:#0f172a;font-size:20px;line-height:1.6;font-weight:800;" class="text-strong">{{ item.number }} {{ item.headline }}</div>
{% if item.body %}
<div style="margin-top:12px;border-left:3px solid #3b82f6;padding:12px 16px;background:#f8fafc;font-family:'Apple SD Gothic Neo','Noto Sans KR',sans-serif;color:#334155;font-size:15px;line-height:1.9;white-space:pre-line;" class="text-body">{{ item.body }}</div>
{% endif %}
{% if item.tldr %}
<div style="margin-top:12px;padding:10px 14px;background:#f0fdf4;border-radius:6px;font-family:'Apple SD Gothic Neo','Noto Sans KR',sans-serif;color:#166534;font-size:14px;line-height:1.6;font-weight:600;">&#9679; 시장 의미: {{ item.tldr }}</div>
{% endif %}
{% if item.source_label %}
<div style="padding-top:10px;">
{% if item.source_url %}
<a href="{{ item.source_url }}" style="display:inline-block;padding:6px 10px;border:1px solid #dbeafe;border-radius:999px;color:#1d4ed8;font-size:12px;font-weight:700;text-decoration:none;background:#f8fbff;">{{ item.source_label }}</a>
{% else %}
<span style="display:inline-block;padding:6px 10px;border:1px solid #e2e8f0;border-radius:999px;color:#64748b;font-size:12px;font-weight:700;background:#f8fafc;" class="text-muted">{{ item.source_label }}</span>
{% endif %}
</div>
{% endif %}
{% endfor %}
</td></tr>
</table>
</td></tr>
