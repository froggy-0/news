{# 변수: news_items, news_status_text #}
{% from "email_macros.html.j2" import section_label %}
<tr><td style="padding:0;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
<tr>
<td class="section-pad" style="padding:34px 40px 36px 40px;border-bottom:1px solid #1c1b1b;">
{{ section_label("주요 뉴스", "#02e600") }}
{% if not news_items %}
<div style="padding-top:18px;font-family:'Apple SD Gothic Neo','Noto Sans KR','Malgun Gothic',sans-serif;color:#888888;font-size:15px;line-height:1.9;" class="text-muted">{{ news_status_text or "이번 집계에서는 주요 뉴스를 확인하지 못했어요." }}</div>
{% endif %}
{% for item in news_items %}
<div style="padding-top:{% if loop.first %}22px{% else %}26px{% endif %};{% if not loop.first %}margin-top:22px;border-top:1px solid #1c1b1b;{% endif %}">
<div style="font-family:'SFMono-Regular','Menlo','Consolas',monospace;font-size:10px;line-height:1.8;letter-spacing:0.14em;text-transform:uppercase;" class="text-muted">
<span class="accent" style="color:#02e600;">{{ item.source_kind or "뉴스" }}</span>{% if item.source_name %} <span style="color:#888888;">&#183;</span> <span style="color:#ffffff;" class="text-strong">{% if item.source_url %}<a href="{{ item.source_url }}" style="color:#ffffff;text-decoration:none;">{{ item.source_name }}</a>{% else %}{{ item.source_name }}{% endif %}</span>{% endif %}
</div>
<div style="padding-top:12px;font-family:'Apple SD Gothic Neo','Noto Sans KR','Malgun Gothic',sans-serif;color:#ffffff;font-size:25px;line-height:1.48;font-weight:800;letter-spacing:-0.04em;" class="text-strong">{{ item.number }} {{ item.headline }}</div>
{% if item.body %}
<div style="padding-top:14px;font-family:'Apple SD Gothic Neo','Noto Sans KR','Malgun Gothic',sans-serif;color:#c6c6c6;font-size:15px;line-height:1.95;white-space:pre-line;" class="text-body">{{ item.body }}</div>
{% endif %}
{% if item.tldr %}
<div style="padding-top:14px;font-family:'Apple SD Gothic Neo','Noto Sans KR','Malgun Gothic',sans-serif;color:#c6c6c6;font-size:14px;line-height:1.9;" class="text-body">
<span style="font-family:'SFMono-Regular','Menlo','Consolas',monospace;color:#888888;font-size:10px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;" class="text-muted">시장 의미</span>
<span style="display:inline-block;padding-left:10px;color:#ffffff;" class="text-strong">{{ item.tldr }}</span>
</div>
{% endif %}
</div>
{% endfor %}
</td>
</tr>
</table>
</td></tr>
