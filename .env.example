# Core
TIMEZONE=Asia/Seoul
CACHE_DIR=.cache
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_BRIEF_VALIDATION_ENABLED=true
OPENAI_BRIEF_VALIDATION_MODEL=gpt-5-mini
OPENAI_BRIEF_MAX_REWRITES=1
OPENAI_WEB_SEARCH_ENABLED=true
OPENAI_WEB_SEARCH_MODEL=gpt-5-mini
OPENAI_WEB_SEARCH_MAX_RESULTS=3
OPENAI_REASONING_EFFORT=low
OPENAI_MAX_OUTPUT_TOKENS=1700
OPENAI_PROMPT_CACHE_KEY=morning-market-brief
PROMPT_TEMPLATE_DIR=src/morning_brief/prompts
PROMPT_TEMPLATE_VERSION=market_brief_v3
FRED_API_KEY=
PERPLEXITY_API_KEY=
GROK_API_KEY=
GROK_MODEL=grok-4.20-beta-latest-non-reasoning
RESEARCH_PROVIDER=perplexity
ENABLE_LEGACY_NEWS_FALLBACK=true
ENABLE_OFFICIAL_X_SIGNALS=true
OFFICIAL_X_LOOKBACK_HOURS=48
OFFICIAL_X_MAX_ITEMS=4
MAX_NEWS_ITEMS=5
NEWSAPI_KEY=

# Gmail
GMAIL_SENDER=yourgmail@gmail.com
GMAIL_RECIPIENT=recipient1@email.com,recipient2@email.com
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json
GMAIL_OAUTH_INTERACTIVE=true
SEND_EMAIL=true

# Output
OUTPUT_DIR=outputs
LOG_LEVEL=INFO
